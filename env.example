# QuickBooks Online OAuth (v9b)
# Register an app at https://developer.intuit.com/app/developer/myapps
# Add the production redirect URI to that app:
#   https://<your-vercel-domain>/api/qbo/auth/callback
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=
# 'sandbox' for testing against Intuit sandbox company, 'production' for live
QBO_ENV=sandbox

# Supabase service role key (v9b)
# Found in Supabase Dashboard > Project Settings > API > service_role key.
# Server-only. Bypasses RLS. Used by API routes for qbo_tokens read/write.
# Never expose to client. Vercel: add as Environment Variable, do NOT prefix with NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=

# Public Supabase URL (already hard-coded in src/lib/sb.js but available here for parity)
NEXT_PUBLIC_SUPABASE_URL=https://ulyycjtrshpsjpvbztkr.supabase.co
